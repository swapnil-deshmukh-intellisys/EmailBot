MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/email_dashboard?retryWrites=true&w=majority&appName=email-dashboard
JWT_SECRET=replace-with-strong-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Default SMTP account (Outlook example)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@outlook.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM=your-email@outlook.com

# Microsoft Graph app-only sending (preferred over SMTP when set)
TENANT_ID=your-tenant-id
CLIENT_ID=your-app-client-id
CLIENT_SECRET=your-app-client-secret
GRAPH_SENDER_EMAIL=sender@yourdomain.com

# Microsoft Graph delegated OAuth (multi-account)
MS_OAUTH_TENANT=organizations
MS_OAUTH_CLIENT_ID=your-oauth-client-id
MS_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# 32-byte key recommended (base64). Used to encrypt refresh/access tokens in Mongo.
TOKEN_ENC_KEY=replace-with-base64-32-bytes

# Microsoft Graph delegated OAuth (multi-account) - preferred env names
MS_TENANT_ID=common
MS_CLIENT_ID=your-oauth-client-id
MS_CLIENT_SECRET=your-oauth-client-secret
MS_REDIRECT_URI=http://localhost:3000/api/graph-oauth/callback

# Optional: show these emails in the sender dropdown even before they are connected via OAuth
PRESET_SENDER_EMAILS=sam@theentrepreneurialchronicle.com,clara@theentrepreneurialchronicle.com

# Optional: separate sender lists by project (for dashboard filter TEC/TUT)
#   TEC (The Entrepreneurial Chronicle)
PRESET_SENDER_EMAILS_TEC=sam@theentrepreneurialchronicle.com,clara@theentrepreneurialchronicle.com,sophia@theentrepreneurialchronicle.com,jess@theentrepreneurialchronicle.com,diana@theentrepreneurialchronicle.com,victoria@theentrepreneurialchronicle.com,alina@theentrepreneurialchronicle.com,amelia@theentrepreneurialchronicle.com,grace@theentrepreneurialchronicle.com,eliana@theentrepreneurialchronicle.com,liam@theentrepreneurialchronicle.com,emma@theentrepreneurialchronicle.com,fiona@theentrepreneurialchronicle.com,daniel@theentrepreneurialchronicle.com,lacy@theentrepreneurialchronicle.com
#   TUT (The Unicorn Times)
PRESET_SENDER_EMAILS_TUT=Matt@theunicorntimes.com,Jordan@theunicorntimes.com,Jessica@theunicorntimes.com,ethan@theunicorntimes.com,Lily@theunicorntimes.com,Jasmin@theunicorntimes.com,kevin@theunicorntimes.com,Peter@theunicorntimes.com,Tyler@theunicorntimes.com,Olivia@theunicorntimes.com
